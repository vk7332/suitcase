{
    "compilerOptions": {
        "target": "ES2019",
        "module": "commonjs",
        "rootDir": "./",
        "outDir": "../dist",
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "typeRoots": ["./types", "../node_modules/@types"]
    },
    "include": [
        "**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
