{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "rootDir": "./",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,

    "typeRoots": [
      "./node_modules/@types",
      "./types"
    ]
  },

  "include": [
    "**/*.ts",
    "**/*.d.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}
